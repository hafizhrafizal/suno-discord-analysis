# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# ── Paths ─────────────────────────────────────────────────────────────────────
# Override if deploying to a container/cloud where the working directory differs.
# DB_PATH=discord_data.db
# CHROMA_PATH=./chroma_db

# ── Upload limits ─────────────────────────────────────────────────────────────
# Maximum CSV upload size in megabytes (default: 50)
# MAX_UPLOAD_MB=50

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Pre-load an API key at server startup (recommended for production).
# Users can still override it via the Config page for the current session.
# OPENAI_API_KEY=sk-...

# ── Security ──────────────────────────────────────────────────────────────────
# Set a secret token to protect all /api/* endpoints.
# Clients must send: Authorization: Bearer <your-secret-here>
# Leave blank (or unset) to disable authentication (local/trusted-network use only).
# API_SECRET=change-me-to-a-long-random-string
