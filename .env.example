# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# ── Vector backend ─────────────────────────────────────────────────────────────
# Choose one of: qdrant | chroma_persistent | chroma_http
# Default: qdrant
VECTOR_DB=qdrant

# ── Qdrant (VECTOR_DB=qdrant) ──────────────────────────────────────────────────
# Self-hosted:  QDRANT_URL=http://localhost:6333
# Cloud:        QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=          # leave blank for unauthenticated local Qdrant

# ── ChromaDB persistent (VECTOR_DB=chroma_persistent) ─────────────────────────
# Vectors are stored as files inside this directory.
CHROMA_PATH=./chroma_db

# ── ChromaDB HTTP (VECTOR_DB=chroma_http) ─────────────────────────────────────
# Run a ChromaDB server: chroma run --path ./chroma_db --port 8001
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_SSL=false
CHROMA_AUTH_TOKEN=       # optional; sent as Authorization: Bearer <token>

# ── Paths ──────────────────────────────────────────────────────────────────────
# Override if deploying to a container/cloud where the working directory differs.
# DB_PATH=discord_data.db

# ── Upload limits ──────────────────────────────────────────────────────────────
# Maximum CSV upload size in megabytes (default: 50)
# MAX_UPLOAD_MB=50

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Pre-load an API key at server startup (recommended for production).
# OPENAI_API_KEY=sk-...

# ── Security ───────────────────────────────────────────────────────────────────
# Set a secret token to protect all /api/* endpoints.
# API_SECRET=change-me-to-a-long-random-string
